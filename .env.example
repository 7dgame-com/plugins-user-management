# 用户管理插件 - 环境变量
# 复制为 .env 并修改

# 后端 API 端口
PORT=8086

# 数据库（共享主系统 MySQL）
DB_HOST=host.docker.internal
DB_PORT=3306
DB_NAME=bujiaban
DB_USER=bujiaban
DB_PASSWORD=testpassword

# Redis（共享主系统 Redis）
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_DB=1

# JWT
JWT_SECRET=change-this-in-production
